{
  "name": "apex-notes",
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "build:web": "esbuild web/app.js --bundle --format=iife --loader:.md=text --outfile=web/app.bundle.js",
    "build:web:prod": "esbuild web/app.js --bundle --format=iife --loader:.md=text --minify --outfile=web/app.bundle.js",
    "build:site": "npm run build:web:prod",
    "serve": "npm run build:web && python3 -m http.server 8765 -d web",
    "dev": "tauri dev",
    "build": "npm run build:web:prod && tauri build",
    "test": "node --test web/*.test.js",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "lucide": "1.16.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.1",
    "esbuild": "^0.28.0"
  }
}
