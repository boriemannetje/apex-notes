{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Apex Notes",
  "version": "0.1.4",
  "identifier": "app.apex.notes",
  "build": {
    "beforeDevCommand": "npm run serve",
    "devUrl": "http://localhost:8765",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Apex Notes",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}
